{
    "app_name": "Aegis Wireless",
    "version": "1.0.0",
    "description": "WiFi Security Analysis Tool",
    "admin_mode": true,
    "policy": {
        "require_vpn": true,
        "minimum_encryption": "WPA2",
        "allow_open_networks": false,
        "max_acceptable_risk_score": 40,
        "auto_enforce_disconnect": false,
        "blocked_ssids": [],
        "trusted_ssids": [],
        "auto_scan_on_start": true,
        "scan_interval_minutes": 15,
        "org_name": ""
    },
    "scan_settings": {
        "default_port_range": [
            1,
            1024
        ],
        "common_ports": [
            21,
            22,
            23,
            25,
            53,
            80,
            110,
            135,
            139,
            143,
            443,
            445,
            993,
            995,
            3306,
            3389,
            5900,
            8080,
            8443
        ],
        "scan_timeout_seconds": 1.0,
        "max_threads": 50
    },
    "risk_thresholds": {
        "open_port_warning": 5,
        "dangerous_ports": [
            23,
            135,
            139,
            445,
            3389,
            5900
        ],
        "safe_encryption_types": [
            "WPA2",
            "WPA3",
            "WPA2-Enterprise",
            "WPA3-Enterprise"
        ]
    },
    "notifications": {
        "enabled": true,
        "cooldown_seconds": 30,
        "on_dangerous_network": true,
        "on_open_network": true,
        "on_blacklisted_network": true,
        "on_vpn_missing": true,
        "on_scan_complete": true,
        "on_startup": true,
        "on_connection_blocked": true,
        "on_connection_allowed": true
    },
    "tray": {
        "run_on_startup": true,
        "show_exit_button": true,
        "user_can_disable_notifications": false,
        "user_can_toggle_startup": false
    },
    "logging": {
        "log_directory": "logs",
        "log_format": "%(asctime)s | %(levelname)-8s | %(message)s",
        "max_log_files": 30
    }
}
